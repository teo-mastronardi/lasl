# ---------------------------------------------------------------------------
# Leamington Adult Soccer League — environment variables
# ---------------------------------------------------------------------------
# Copy this file to ".env" for local development and add the same variable in
# the Vercel dashboard (Project Settings -> Environment Variables) for production.
#
# All Vite env vars exposed to the browser MUST be prefixed with VITE_.
# ---------------------------------------------------------------------------

# The ID of the Google Sheet that powers the site.
# Find it in the sheet URL between "/d/" and "/edit":
#   https://docs.google.com/spreadsheets/d/THIS_IS_THE_ID/edit
#
# The sheet MUST be shared as: "Anyone with the link" -> "Viewer".
VITE_SHEET_ID=